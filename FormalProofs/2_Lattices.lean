-- manually completed by Tally and Alex
lemma lemma_2_8 [Lattice L] (a b : L) : List.TFAE [a ≤ b, a ⊔ b = b, a ⊓ b = a] := by
  tfae_have 1 → 2 := by
    intro h
    rw [sup_eq_right]
    exact h
  tfae_have 2 → 3 := by
    intro h
    have h' : a ⊓ (a ⊔ b) = a ⊓ b :=
      congrArg (fun x => a ⊓ x) h
    rw [inf_sup_self] at h'
    exact h'.symm
  tfae_have 3 → 1 := by
    intro h
    rw [← inf_eq_left]
    exact h
  tfae_finish


-- TODO: This proof/proof statement is not correct. It fails for general lattices
--       because it uses the fact that the lattice is totally ordered.
/-- For a **totally ordered** domain `L`, order-preserving maps preserve binary `⊓` and `⊔`.
This fails for general lattices; see e.g. Blyth, *Lattices and ordered algebraic structures* -/
theorem proposition_2_19_i [LinearOrder L] [Lattice K] (f : L → K) :
  List.TFAE [Monotone f, (∀ a b, f (a ⊓ b) = f a ⊓ f b), (∀ a b, f (a ⊔ b) = f a ⊔ f b)] := by
  tfae_have 1 → 2 := by
    intro hf a b
    rcases le_total a b with hab | hba
    · rw [inf_eq_left.2 hab]
      exact (inf_eq_left.2 (hf hab)).symm
    · rw [inf_eq_right.2 hba]
      exact (inf_eq_right.2 (hf hba)).symm
  tfae_have 2 → 3 := by
    intro h
    have hf : Monotone f := fun {x y} hxy => by
      calc
        f x = f (x ⊓ y) := by rw [inf_eq_left.2 hxy]
        _ = f x ⊓ f y := h x y
        _ ≤ f y := inf_le_right
    intro a b
    rcases le_total a b with hab | hba
    · rw [sup_eq_right.2 hab]
      exact (sup_eq_right.2 (hf hab)).symm
    · rw [sup_eq_left.2 hba]
      exact (sup_eq_left.2 (hf hba)).symm
  tfae_have 3 → 1 := by
    intro h a b hab
    rw [← sup_eq_right.2 hab, h a b]
    exact le_sup_left
  tfae_finish

-- completed by cursor agent with MCP and lean4-skills
-- ∃ e : α ≃o β, e.toFun = f means that there exists an order isomorphism between α and β
-- such that the function f is the underlying function of the order isomorphism
theorem proposition_2_19_ii [Lattice α] [Lattice β] (f : α → β) :
  (∃ e : α ≃o β, e.toFun = f) ↔
  ((Function.Bijective f) ∧
    (∀ x y, f (x ⊓ y) = f x ⊓ f y) ∧
    (∀ x y, f (x ⊔ y) = f x ⊔ f y)) := by
  constructor
  · rintro ⟨e, rfl⟩
    exact ⟨Equiv.bijective (e : α ≃ β), e.map_inf, e.map_sup⟩
  · rintro ⟨hf, _hinf, hsup⟩
    have hreflect : ∀ {a b : α}, f a ≤ f b → a ≤ b := by
      intro a b hab
      have hfb : f (a ⊔ b) = f b := by rw [hsup, sup_eq_right.2 hab]
      have hab' : a ⊔ b = b := hf.injective hfb
      rw [← hab']
      exact le_sup_left
    let e : α ≃ β := Equiv.ofBijective f hf
    refine ⟨e.toOrderIso ?_ ?_, rfl⟩
    · intro a b hab
      dsimp [e]
      rw [← sup_eq_right.2 hab, hsup]
      exact le_sup_left
    · intro a b hab
      apply hreflect
      calc
        f (e.symm a) = a := Equiv.apply_symm_apply e a
        _ ≤ b := hab
        _ = f (e.symm b) := (Equiv.apply_symm_apply e b).symm



-- definition of a lattice isomorphism generated by Cursor agent with mcp and lean4-skills
/-- `f` is a lattice isomorphism: bijective and preserves binary meet and join -/
def IsLatticeIso [Lattice α] [Lattice β] (f : α → β) : Prop :=
  Function.Bijective f ∧ (∀ x y, f (x ⊓ y) = f x ⊓ f y) ∧ (∀ x y, f (x ⊔ y) = f x ⊔ f y)



