-- Cursor agent with MCP and lean4-skills finished this proof
lemma lemma_2_22_ii [PartialOrder P] (S : Set P) (x : P)
  (sInfS : P) (hsInfS : IsGLB S sInfS) :
  x ≤ sInfS ↔ ∀ s : S, x ≤ s := by
  constructor
  · intro h s
    exact le_trans h (hsInfS.1 s.2)
  · intro h
    exact hsInfS.2 (by
      intro s hs
      exact h ⟨s, hs⟩)


